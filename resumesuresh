    key                  = "AZUR-N-1-AZUR-RG-1.tfstate"
    resource_group_name  = "AZUR-P-1-AZUR-RG-50"
    storage_account_name = "azuraps1azursa50"
    container_name       = "tfstate-product"
    subscription_id      = "e63b08c3-d314-48d8-b10a-c58199bb78b1"
    tenant_id            = "4cc65fd6-9c76-4871-a542-eb12a5a7800c"
    use_azuread_auth     = true
  }
}

module "azurerm-provider" {
  source = "git::https://facloud@dev.azure.com/facloud/AzureProduct-Modules/_git/azurerm-provider?ref=v3.0.0"
}

provider "azurerm" {
  skip_provider_registration = true
  subscription_id            = "50bfd09a-e376-4e72-86d9-6a493b0e1184"
  features {}
}

# VNET
locals {
  vnet_resoure_group_name = "AZUR-N-1-AZUR-RG-1"
  vnet_name               = "AZUR-N-1-AZUR-VN-1"
  vnet_location           = "westus2"
  vnet_address_space      = "10.65.16.0/22"

  hub_virtual_network_address_space       = ["10.65.8.0/22"] # AZUR-P-1-AZUR-VN-2 (TransitHub)
  network_virtual_appliance_address_space = "10.65.8.160/27" # PaloAltoTrustSubnet
}

# Subnets
locals {
  subnets = {
    for type in distinct([for subnet in jsondecode(file("subnets.json")) : subnet.type]) : type => {
      for subnet in jsondecode(file("subnets.json")) : subnet.map_key => subnet if subnet.type == type
    }
  }
}

# --------------------------------------------------------------------------------------
# Create RG, VNet and Subnets
# --------------------------------------------------------------------------------------

module "landing_zone" {
  source = "git::https://facloud@dev.azure.com/facloud/AzureProduct-Modules/_git/landing-zone-core?ref=v3.0.0"

  resource_group_name           = local.vnet_resoure_group_name
  virtual_network_name          = local.vnet_name
  location                      = local.vnet_location
  virtual_network_address_space = local.vnet_address_space
  custom_subnets_map            = local.subnets
  vnet_network_group_id         = "/subscriptions/2c20e80b-16ba-4abb-880b-1b506469b3c6/resourceGroups/AZUR-P-100-AZUR-RG-100/providers/Microsoft.Network/networkManagers/AZUR-P-100-AZUR-NM-2/networkGroups/VNET_Non-Production"
}

# Create Route Tables and associate subnets to them

module "non_prod_route_table_standard" {
  source = "git::https://facloud@dev.azure.com/facloud/AzureProduct-Modules/_git/route-table?ref=v5.0.0"

  resource_group_name                        = module.landing_zone.resource_group_name
  route_table_name                           = "StandardSubnet-Outbound"
  network_virtual_appliance_load_balancer_ip = "10.65.8.180"
  location                                   = local.vnet_location
  virtual_network_address_space              = local.vnet_address_space
  hub_virtual_network_address_space          = local.hub_virtual_network_address_space
  network_virtual_appliance_address_space    = local.network_virtual_appliance_address_space
  route_table_type                           = "spoke_standard"
  subnet_map_for_association                 = module.landing_zone.custom_subnets["standard"]
}

module "non_prod_route_table_custom_subnet" {
  source = "git::https://facloud@dev.azure.com/facloud/AzureProduct-Modules/_git/route-table?ref=v5.0.0"

