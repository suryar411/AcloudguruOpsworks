  resource_group_name = module.landing_zone_westus2.resource_group_name
  scopes              = [azurerm_private_dns_resolver.westus2.id]
  description         = "Queries Per Second (QPS) is over 9000." # Max is 10000.
  frequency           = "PT5M"
  window_size         = "PT5M"
