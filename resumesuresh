    subscription_id      = "e63b08c3-d314-48d8-b10a-c58199bb78b1"
    tenant_id            = "4cc65fd6-9c76-4871-a542-eb12a5a7800c"
    use_azuread_auth     = true
  }
}

module "azurerm-provider" {
  source = "git::https://facloud@dev.azure.com/facloud/AzureProduct-Modules/_git/azurerm-provider?ref=v3.0.1"
}

# Subscription ID
provider "azurerm" {
  skip_provider_registration = true
  subscription_id            = "e63b08c3-d314-48d8-b10a-c58199bb78b1"
  features {}
}

# VNET
locals {
  vnet_resoure_group_name                    = "AZUR-P-1-AZUR-RG-1"
  vnet_name                                  = "AZUR-P-1-AZUR-VN-1"
  vnet_location                              = "westus2"
  vnet_address_space                         = "10.65.4.0/22"
  mgmt_subnet_address_space                  = "10.65.4.0/24"
  network_virtual_appliance_load_balancer_ip = "10.65.4.180"
}

#Subnets
locals {
  subnets = {
    for type in distinct([for subnet in jsondecode(file("subnets.json")) : subnet.type]) : type => {
      for subnet in jsondecode(file("subnets.json")) : subnet.map_key => subnet if subnet.type == type
    }
  }
}

